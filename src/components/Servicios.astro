---
import { getCollection } from 'astro:content';
const servicios = await getCollection('servicios');
---
<header>
	<div class="contenedor-titulo">
		<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-package"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M12 3l8 4.5l0 9l-8 4.5l-8 -4.5l0 -9l8 -4.5" /><path d="M12 12l8 -4.5" /><path d="M12 12l0 9" /><path d="M12 12l-8 -4.5" /><path d="M16 5.25l-8 4.5" /></svg>
	    <h2>Servicios</h2>
	</div>
	    <p>Conoce nuestros distintos tipos de mudanzas.</p>
</header>
<ul id="servicios" class="servicios__layout">
{
servicios.map(servicio => {
    // Debes acceder a través de .data
    const titulo = servicio.data.name; 
	const imagen = servicio.data.img;
	const descripcion = servicio.data.description;
    return (
	<li class="servicio__item efecto-sombreado"
	style={`
        background-image: url('/mudanza/images/${imagen}');
        background-size: cover;
        background-repeat: no-repeat;
        background-position: center;
    `}>
		<article class="servicio__tarjeta" aria-labelledby="servicio-residencial">
        	<h3 id="servicio-residencial" class="servicio__titulo">{titulo}</h3>
			<div class="wrapper">
        	    <p class="servicio__descripcion">{descripcion}</p>
			    <div class="servicio__botones">
        	        <a href="/cotizar" class="servicio__boton" role="button">Cotizar</a>
        		    <a href="/cotizar" class="servicio__boton" role="button">Más información</a>
			    </div>
			</div>
      	</article>
	</li>
        );
    })
}
</ul>
<style>
	:root{
		--color--primario: #e24e42;
		--color-secundario: #008f95;
		--color-terciario: #e9b000;
		--color-acento: #eb6e80;
	}	
	h2{
		font-size: 2.5rem;
		margin-top: 20px;
		margin-bottom: 20px;
	}
	ol, li, ul {
    	list-style: none;
		padding: 0;
	}
	a {
		text-decoration: none;
	}
	.contenedor-titulo{
		display: flex;
		flex-wrap: nowrap;
		align-items: center;
	}
	.efecto-sombreado {
  		box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
  		transition: transform 0.2s ease, box-shadow 0.2s ease; /* Transición suave para interactividad */
	}

	/* Efecto sutil al pasar el mouse por las tarjetas */
	.efecto-sombreado:hover {
  		transform: translateY(-2px);
  		box-shadow: 0 12px 40px 0 black; /* Brillo verde neón muy tenue */
	}

	
	
	.servicios__layout{
		display: grid;
		grid-template-columns: repeat(
			auto-fit, minmax(300px, 1fr)
		);
		grid-auto-rows: 400px;
		box-sizing: border-box;
		gap: 15px;
	}
	.servicio__item {
		display: flex;
		align-items: flex-end;
		border-radius: 10px;
		overflow: hidden;
	}

	.servicio__tarjeta{
		background-color: var(--color--primario);
		border-radius: 10px 10px 0 0;
		box-sizing: border-box;
		width: 100%;
		max-height: 60px;
		overflow: hidden;
		display: flex;
		flex-wrap: wrap;
		transition: max-height 0.8s cubic-bezier(0.79,0.14,0.15,0.86);
	}
	
	.servicio__tarjeta:hover{
		max-height: 255px;
	}

	.servicio__titulo{
		padding: 15px;
		box-sizing: border-box;
		width: 100%;
		height: 60px;
		flex-shrink: 0;
		margin: 0px;
		color: white;
		font-size: 1.5rem;
	
	}

	.wrapper{
		padding-left: 15px;
		padding-right: 15px;
		padding-bottom: 15px;
		padding-top: 0px;
		display: flex;
		flex-direction: column;
		gap: 15px;
	}
	.servicio__descripcion{
		width: 100%;
		box-sizing: border-box;
		font-size: 1rem;
		color: white;
		margin: 0;

	}
	.servicio__botones{
		display: flex;
		gap: 15px;
	}
	.servicio__boton{
		display: flex;
		justify-content: center;
		align-items: center;
		background-color: #ff9d07;
        color: black;
        font-size: 1rem;
		padding: 5px;
        height: 25px;
        border-radius: 10px;
	}
	
</style>