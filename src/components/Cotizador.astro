                "detalles detalles"
                "enviar enviar"
            ;
        }
        
  /* Estilos para móviles */
    }


</style>
<script>
  // Seleccionamos el formulario y el botón
  const form = document.getElementById('form-cotizador');
  const btn = document.getElementById('enviar');
  const btnTexto = btn.querySelector('.btn-texto');

  form.addEventListener('submit', async (e) => {
    e.preventDefault(); // Evita que la página se recargue

    // 1. Estado inicial: Cargando
    btn.classList.remove('exito', 'error');
    btn.classList.add('cargando');
    btnTexto.textContent = 'Enviando...';

    try {
      // 2. Enviamos los datos al PHP usando Fetch API
      const formData = new FormData(form);
      const response = await fetch(form.action, {
        method: form.method,
        body: formData
      });

      if (response.ok) {
        // 3a. Estado de Éxito
        btn.classList.remove('cargando');
        btn.classList.add('exito');
        btnTexto.textContent = '¡Solicitud enviada!';
        form.reset(); // Limpia los campos del formulario
      } else {
        throw new Error('El servidor devolvió un error');
      }

    } catch (error) {
      // 3b. Estado de Error
      btn.classList.remove('cargando');
      btn.classList.add('error');
      btnTexto.textContent = 'Error al enviar';
      
      // Mostramos la alerta que pediste
      alert('Hubo un problema de conexión al intentar enviar tu solicitud. Por favor, revisa tus datos o intenta más tarde.');

      // Restauramos el botón después de 3 segundos para que puedan intentar de nuevo
      setTimeout(() => {
        btn.classList.remove('error');
        btnTexto.textContent = 'Enviar solicitud de presupuesto';
      }, 3000);
    }
  });
</script>