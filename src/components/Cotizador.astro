<style>
	.contenedor-titulo{
		display: flex;
		flex-wrap: nowrap;
		align-items: center;
	}
    h2{
		font-size: 2.5rem;
		margin-top: 20px;
		margin-bottom: 20px;
	}
    
    #cotizador-layout{
  display: flex;
  flex-wrap: wrap;
  gap: 30px;
}

.contacto-layout {
  width: 100%;
  display: flex;
  flex-wrap: wrap;
  gap: 30px;
}


.cotizador-columna{ /* corregir la altura para que alcance el mapa */
  flex: 1 1 400px;
  box-sizing: border-box;
  background: white;
  border-radius: 10px;

  box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);

}

#form-cotizador{
  display: flex;
  flex-wrap: wrap;
  align-content: center;
  padding: 10px;
}

#formulario{
  display: grid;
  box-sizing: border-box;
  grid-template-areas: 
  "nombre nombre"
  "correo telefono"
  "direccion-origen direccion-destino"
  "edificio-origen edificio-destino"
  "tipo-servicio fecha"
  "detalles detalles"
  "detalles detalles"
  "enviar enviar"
  ;
  gap: 15px;
  grid-auto-rows: 45px;
  border: none;
  margin: 0;
  padding: 0px;
  width: 100%;
  min-width: 0; /* Nuestra corrección anterior */
}

#nombre{
  grid-area: nombre;
}
#correo{
    grid-area: correo;
}
#telefono{
    grid-area: telefono;
}
#direccion-origen{
    grid-area: direccion-origen;
}
#direccion-destino{
    grid-area: direccion-destino;
}
#edificio-origen{
    grid-area: edificio-origen;
}
#edificio-destino{
    grid-area: edificio-destino;
}
#tipo-servicio{
    grid-area: tipo-servicio;
}
#detalles{
  grid-area: detalles;
}

.item-formulario{
  padding: 0px;
  box-sizing: border-box;
  height: 100%;
  min-width: 0;

  padding: 10px 15px;
  box-sizing: border-box;
  font-family: inherit;
  font-size: 15px; /* Tamaño ideal para evitar zoom automático en móviles */
  color: #333;
  background-color: #f8fafc; /* Gris muy clarito para el fondo */
  border: 1px solid #cbd5e1; /* Borde sutil */
  border-radius: 8px; /* Bordes amigables */
  transition: all 0.3s ease; /* Animación fluida */
  outline: none;
}
.item-formulario:focus {
  background-color: #ffffff;
  border-color: #2563eb; /* Azul brillante */
  /* Resplandor exterior azulado */
  box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.2); 
}

#popup {
  display: none;
}

#enviar{
    background-color: #f97316; /* Naranja enérgico, ideal para mudanzas */
    color: white;
    font-weight: 700;
    font-size: 15px;
    text-transform: uppercase;
    letter-spacing: 1px;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    box-shadow: 0 4px 6px rgba(249, 115, 22, 0.3);
    grid-area: enviar;
    position: relative;
  overflow: hidden; /* Evita que la animación de relleno se salga de los bordes */
  /* Mantén los estilos que ya tenías: */
  transition: background-color 0.3s ease;
}
#enviar:hover {
  background-color: #ea580c; /* Naranja un poco más oscuro */
  transform: translateY(-2px); /* Efecto de que el botón se levanta */
  box-shadow: 0 6px 12px rgba(249, 115, 22, 0.4);
}

/* Efecto al presionar el botón */
#enviar:active {
  transform: translateY(0);
}

/* =========================================
   ANIMACIONES DEL BOTÓN DE ENVIAR
   ========================================= */


#enviar .btn-texto {
  position: relative;
  z-index: 2;
}

#enviar::before {
  content: "";
  position: absolute;
  top: 0; left: 0; bottom: 0;
  width: 0%;
  background-color: #22c55e; /* Verde éxito */
  z-index: 1;
  transition: width 2s ease-in-out; /* Duración de la animación de llenado */
}

/* CLASES DINÁMICAS QUE AGREGARÁ JAVASCRIPT */
#enviar.cargando {
  pointer-events: none; /* Evita múltiples clics */
}

#enviar.cargando::before {
  width: 100%; /* Inicia la animación de relleno */
}

#enviar.exito {
  background-color: #22c55e;
  pointer-events: none;
}

#enviar.error {
  background-color: #ef4444; /* Rojo error */
  animation: vibrar 0.4s ease-in-out; /* Efecto visual de error */
}

@keyframes vibrar {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-5px); }
  50% { transform: translateX(5px); }
  75% { transform: translateX(-5px); }
}



#mapa{
  height: 100%;
  width: 100%;
}
@media (width <= 550px) {
        #formulario{
            grid-template-areas: 
                "nombre nombre"
                "correo correo"
                "telefono telefono"
                "direccion-origen direccion-origen"
                "direccion-destino direccion-destino"
                "edificio-origen edificio-origen"
                "edificio-destino edificio-destino"
                "tipo-servicio fecha"
